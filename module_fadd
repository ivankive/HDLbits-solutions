module top_module (
    input [31:0] a,
    input [31:0] b,
    output [31:0] sum
);//
    
    logic wire1;
    
    add16 Firstadd16 ( .a(a[15:0]), .b(b[15:0]), .cin(), .sum(sum[15:0]), .cout(wire1) );
    add16 Secondadd16 ( .a(a[31:16]), .b(b[31:16]), .cin(wire1), .sum(sum[31:16]), .cout() );
    
endmodule


module add1 ( input a, input b, input cin,   output sum, output cout );

	assign sum = a ^ b ^ cin;
	assign cout = a&b | a&cin | b&cin;

endmodule